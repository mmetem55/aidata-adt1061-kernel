&fd {
	status = "okay";
};

&dsi {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	panel: panel {
		compatible = "sprd,generic-mipi-panel";
		sprd,backlight = <&backlight>;
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0>;

		port {
			reg = <1>;
			panel_in: endpoint {
				remote-endpoint = <&dphy_out>;
			};
		};
	};
};

&dphy {
	status = "okay";
};

&aon_i2c0 {
	status = "okay";
	clock-frequency = <1000000>;

	fan53555_dcdc: regulator@60 {
		compatible = "fcs,fan53555";
		reg = <0x60>;
		regulator-name = "fan53555";
		regulator-min-microvolt = <600000>;
		regulator-max-microvolt = <1230000>;
		regulator-ramp-delay = <64000>;
		regulator-always-on;
		fcs,suspend-voltage-selector = <1>;
	};

	/* A virtual i2c device */
	cpudvfs-dcdc-cpu1@62{
		compatible = "sprd,cpudvfs-regulator-sharkl5pro";
		reg = <0x62>;
		dvfs-dcdc-i2c = <1>;
	};
};

&vddldo0 {
	regulator-always-on;
};

&pmic_fgu {
	monitored-battery = <&bat>;
	sprd,calib-resistance-real = <10000>;
	sprd,calib-resistance-spec = <20000>;
};

&hsphy {
	vdd-supply = <&vddusb33>;
	extcon = <&extcon_gpio>;
};

&usb {
	extcon = <&extcon_gpio>, <&pmic_typec>;
	vbus-supply = <&vddvbus>;
};

&pmic_typec {
	status = "okay";
};

&isp_dvfs {
	status = "okay";
};

&cpp_dvfs {
	status = "okay";
};

&jpg_dvfs {
	status = "okay";
};

&fd_dvfs {
	status = "okay";
};

&mtx_dvfs {
	status = "okay";
};

&dcam_if_dvfs {
	status = "okay";
};

&dcam_axi_dvfs {
	status = "okay";
};

&mmsys_dvfs {
	status = "okay";
};

&sprd_headset {
	compatible = "sprd,headset";
	status = "okay";

	sprd,jack-type = <0>;
	sprd,debounce-interval = <10>;          /* 0x0a */
	sprd,3pole-adc-threshold = <112>;       /* 0x70 */
	sprd,adc-gnd = <328>;                  /* 0x148 */
	sprd,half-adc-gnd = <100>;             /* 0x64 */
	sprd,coefficient = <0xd7f28>;          /* 884520 */
	sprd,irq-threshold-button = <4>;       /* 0x04 */

	/* ADC & GPIO */
	io-channels = <&pmic_adc 20>;          /* 0x14 = Channel 20 */
	io-channel-names = "headmic_in_little";

	gpios = <&pmic_eic 6 GPIO_ACTIVE_HIGH>;
	gpio-names = "aud_int_all";

	/* SoC GPIO */
	mic-gpios = <&ap_gpio 25 GPIO_ACTIVE_HIGH>; /* 0x19 = GPIO 25 */
	lr-gpios = <&ap_gpio 26 GPIO_ACTIVE_HIGH>;  /* 0x1a = GPIO 26 */

	/* NVMEM */
	nvmem-cells = <&headset_adc_fir>, <&headset_adc_sec>;
	nvmem-cell-names = "hp_adc_fir_calib", "hp_adc_sec_calib";

	/* Headset button */
	sprd,headset-button@0 {
		adc-min = <0>;
		adc-max = <480>;                /* 0x1e0 */
		code = <226>;                   /* 0xe2 (KEY_MEDIA) */
	};

	sprd,headset-button@1 {
		adc-min = <481>;                /* 0x1e1 */
		adc-max = <990>;                /* 0x3de */
		code = <115>;                   /* 0x73 (KEY_VOLUMEUP) */
	};

	sprd,headset-button@2 {
		adc-min = <991>;                /* 0x3df */
		adc-max = <2500>;               /* 0x9c4 */
		code = <114>;                   /* 0x72 (KEY_VOLUMEDOWN) */
	};
};

/* Analog Codec */
&sprd_audio_codec_ana {
	status = "okay";
	hp-use-inter-pa = <1>;
	fixed-sample-rate = <48000 48000 48000>;
	digital-codec = <&sprd_audio_codec_dig>;
};

/* VBC v4 Sound Card / sound@0 Overrides */
&sound_vbc_v4_sprd_codec {
	compatible = "sprd,vbc-v4-codec-sc2730";
	status = "okay";
	sprd-audio-card,name = "sprdphone-sc2730";
	sprd-audio-card,headset = <&sprd_headset>;
	sprd,syscon-agcp-ahb = <&audcp_ahb_regs>;

	sprd,spk-ext-pa-names = "ext_spk_r";
	sprd,spk-ext-pa-gpio = <&ap_gpio 29 GPIO_ACTIVE_HIGH>;
	sprd,spk-ext-pa-info = <0x00 0x00 0x04 0x00>;

	sprd-audio-card,widgets =
	"Headphone", "inter HP PA",
	"Speaker", "inter Ear PA";

	sprd-audio-card,routing =
	"HPMIC Pin", "HP Mic Jack",
	"MIC Pin", "Mic Jack",
	"MIC2 Pin", "Aux Mic Jack",
	"inter HP PA", "HP Pin",
	"Ext Spk", "HP Pin",
	"DMIC Pin", "DMic Jack",
	"DMIC1 Pin", "DMic1 Jack",
	"inter Ear PA", "EAR Pin";

};

&sound_sprd_ap_alliis {
	status = "okay";
};

&i2s0 {
	status = "okay";
};

&adi_bus {
	sprd,hw-channels = <2 0x18cc>, <3 0x18cc>, <13 0x1854>, <15 0x1874>,
			 <17 0x1844>,<19 0x1844>, <21 0x1864>, <30 0x1820>,
			 <35 0x19b8>, <39 0x19ac>;
};

&pin_controller {
	pinctrl-names =
	"gpio_121", "gpio_123", "gpio_124", "gpio_125", "gpio_126",
	"gpio_144", "gpio_145", "gpio_146", "gpio_147", "gpio_16";

	pinctrl-0 = <&gpio_121>;
	pinctrl-1 = <&gpio_123>;
	pinctrl-2 = <&gpio_124>;
	pinctrl-3 = <&gpio_125>;
	pinctrl-4 = <&gpio_126>;
	pinctrl-5 = <&gpio_144>;
	pinctrl-6 = <&gpio_145>;
	pinctrl-7 = <&gpio_146>;
	pinctrl-8 = <&gpio_147>;
	pinctrl-9 = <&gpio_16>;

	gpio_121: keyout0 {
		pins = "SHARKL5PRO_KEYOUT0";
		function = "func4";
	};

	gpio_123: keyout2 {
		pins = "SHARKL5PRO_KEYOUT2";
		function = "func4";
	};

	gpio_124: keyin0 {
		pins = "SHARKL5PRO_KEYIN0";
		function = "func4";
	};

	gpio_125: keyin1 {
		pins = "SHARKL5PRO_KEYIN1";
		function = "func4";
	};

	gpio_126: keyin2 {
		pins = "SHARKL5PRO_KEYIN2";
		function = "func4";
	};

	gpio_144: extint0 {
		pins = "SHARKL5PRO_EXTINT0";
		function = "func4";
	};

	gpio_145: extint1 {
		pins = "SHARKL5PRO_EXTINT1";
		function = "func4";
	};

	gpio_146: sda3 {
		pins = "SHARKL5PRO_SDA3";
		function = "func4";
	};

	gpio_147: scl3 {
		pins = "SHARKL5PRO_SCL3";
		function = "func4";
	};

	gpio_16: rffe1_sda {
		pins = "SHARKL5PRO_RFFE1_SDA";
		function = "func4";
	};
};

&modem_dbg_log {
	vddio-supply = <&vddcamio>;
	mipi-switch-en-gpios = <&ap_gpio 55 GPIO_ACTIVE_HIGH>;
	mipi-switch-mode-gpios = <&ap_gpio 8 GPIO_ACTIVE_HIGH>;
};
